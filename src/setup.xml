<?xml version="1.0" encoding="utf-8"?>
<!--suppress XmlUnboundNsPrefix -->
<setupxml>
	<setup key="timeshiftcockpit" title="Setup">
		<item text="Enable plugin" description="Select whether to enable or disable the plugin.">config.plugins.timeshiftcockpit.enabled</item>
		<item text="Permanent timeshift" description="Select to enable permanent timeshift.">config.plugins.timeshiftcockpit.permanent</item>
		<item text="Fixed timeshift service #1" description="Press OK to select service for fixed timeshift #1.">config.plugins.timeshiftcockpit.fixed1</item>
		<item text="Fixed timeshift service #2" description="Press OK to select service for fixed timeshift #2.">config.plugins.timeshiftcockpit.fixed2</item>
		<item text="Recording directory" description="Select directory for timeshift recordings.">config.plugins.timeshiftcockpit.videodir</item>
		<item text="Cover source" description="Select the cover source.">config.plugins.timeshiftcockpit.cover_source</item>
		<item level="2" text="Log level" description="Select debug log level.">config.plugins.timeshiftcockpit.debug_log_level</item>
	</setup>
</setupxml>
